# EdgeEver 本地环境变量模板。
# 使用方式：复制为 .env.local，然后填入你自己的 Cloudflare 账号和资源信息。
# 注意：.env.local 会被 git 忽略，不要把真实 Token 或私有资源 ID 提交到公开仓库。

# Cloudflare 账号 ID。
# 可通过 `bunx wrangler whoami` 查看。
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare API Token。
# 本地已经通过 `wrangler login` 登录时可以留空；CI/CD 自动部署时再填写。
CLOUDFLARE_API_TOKEN=

# Worker 服务名称。
# 默认会部署为名叫 edgeever 的 Cloudflare Worker。
EDGE_EVER_WORKER_NAME=edgeever

# D1 数据库名称。
# 创建命令：`bunx wrangler d1 create edgeever`
EDGE_EVER_D1_DATABASE_NAME=edgeever

# D1 数据库 ID。
# 创建 D1 后，把 wrangler 返回的 database_id 填到这里。
# Cloudflare Git 自动部署时，也需要在 Build Variables 里设置同名变量。
# 脚本会生成临时 .wrangler.generated.toml，不需要把个人 D1 ID 提交到公开仓库。
EDGE_EVER_D1_DATABASE_ID=00000000-0000-0000-0000-000000000000

# R2 生产资源桶名称。
# 创建命令：`bunx wrangler r2 bucket create edgeever-resources`
EDGE_EVER_R2_BUCKET_NAME=edgeever-resources

# R2 预览/本地开发资源桶名称。
# 可选；用于 Wrangler preview/dev 场景隔离测试附件。
EDGE_EVER_R2_PREVIEW_BUCKET_NAME=edgeever-resources-preview

# 登录账号。
EDGE_EVER_AUTH_USERNAME=admin

# 登录密码的 PBKDF2-SHA256 hash。
# 生成命令：`bun run auth:hash -- <你的密码>`
# 也可以用 `EDGE_EVER_TIANMA_AUTH_PASSWORD_HASH` / `EDGE_EVER_DEMO_AUTH_PASSWORD_HASH`
# 给多实例配置不同密码。
# 线上部署时建议把对应 hash 配成 Cloudflare Worker Secret。
EDGE_EVER_AUTH_PASSWORD_HASH=

# Web session 有效期，单位：天。服务端会限制在 1-90 天。
EDGE_EVER_SESSION_TTL_DAYS=30

# 前端访问 API 的基础地址。
# 本地开发默认指向 Wrangler dev：`bun run dev:api`
VITE_API_BASE_URL=http://127.0.0.1:8787

# 多实例部署模板。
# 使用 `EDGE_EVER_INSTANCE=tianma bun run deploy` 或 `bun run deploy:tianma` 时，
# 脚本会优先读取 `EDGE_EVER_TIANMA_*`，再回退到上面的通用 `EDGE_EVER_*`。
# `demo` 实例同理。真实 D1 ID 只填到本地 `.env.local` 或 Cloudflare Build Variables。

# 私人实例：tianma.edgeever.org
EDGE_EVER_TIANMA_WORKER_NAME=edgeever-tianma
EDGE_EVER_TIANMA_CUSTOM_DOMAIN=tianma.edgeever.org
EDGE_EVER_TIANMA_D1_DATABASE_NAME=edgeever-tianma
EDGE_EVER_TIANMA_D1_DATABASE_ID=00000000-0000-0000-0000-000000000000
EDGE_EVER_TIANMA_R2_BUCKET_NAME=edgeever-tianma-resources
EDGE_EVER_TIANMA_R2_PREVIEW_BUCKET_NAME=edgeever-tianma-resources-preview

# 公开演示实例：demo.edgeever.org
# 如果 Workers Custom Domain 暂未稳定生效，可以用 Route Pattern + DNS CNAME。
EDGE_EVER_DEMO_WORKER_NAME=edgeever-demo
EDGE_EVER_DEMO_ROUTE_PATTERN=demo.edgeever.org/*
EDGE_EVER_DEMO_D1_DATABASE_NAME=edgeever-demo
EDGE_EVER_DEMO_D1_DATABASE_ID=00000000-0000-0000-0000-000000000000
EDGE_EVER_DEMO_R2_BUCKET_NAME=edgeever-demo-resources
EDGE_EVER_DEMO_R2_PREVIEW_BUCKET_NAME=edgeever-demo-resources-preview
